# ─────────────────────────────────────────────────────────────
#  论文助手 后端环境配置
#  复制此文件为 .env 并填写真实配置
# ─────────────────────────────────────────────────────────────

# 服务端口
PORT=3001

# 运行模式（development / production）
NODE_ENV=development

# JWT 密钥（务必修改为随机长字符串）
JWT_SECRET=your-very-secret-jwt-key-change-me

# 站点名称（出现在邮件标题和正文中）
SITE_NAME=论文助手

# ─── SMTP 邮件配置 ────────────────────────────────────────────
# 填写后即可真实发送验证码邮件
# 未填写时将在服务端控制台打印验证码（仅开发调试用）

# ── QQ邮箱 示例 ──────────────────────────────────────────────
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_qq@qq.com
# SMTP_PASS=your_smtp_authorization_code   # QQ邮箱授权码（不是登录密码）
# SMTP_FROM=your_qq@qq.com

# ── 163邮箱 示例 ─────────────────────────────────────────────
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your_account@163.com
# SMTP_PASS=your_smtp_authorization_code   # 163邮箱授权码
# SMTP_FROM=your_account@163.com

# ── Gmail 示例（需开启两步验证+应用专用密码）─────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_account@gmail.com
# SMTP_PASS=your_app_specific_password
# SMTP_FROM=your_account@gmail.com

# ─── 取消注释下面4行并填写你的真实邮箱配置 ──────────────────
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
